ax.legend()
ax.grid(True, alpha=0.3)

# --- Monthly Returns Heatmap ---
ax = axes[2]
monthly_ga = ga_daily_returns.resample('M').sum() * 100
monthly_bench = benchmark_daily_returns.resample('M').sum() * 100
monthly_df = pd.DataFrame({
