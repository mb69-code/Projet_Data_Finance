}, index=monthly_bench.index)
monthly_df.index = monthly_df.index.strftime('%b %Y')

sns.heatmap(monthly_df.T, annot=True, fmt='.1f', cmap='RdYlGn', center=0,
            ax=ax, cbar_kws={'label': 'Monthly Return (%)'}, linewidths=0.5)
